# Copie para .env e ajuste os valores. NUNCA versione o .env real.

# Servidor
PORT=3333
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/desperte_mulher
# Em produção (Supabase) use a connection string com SSL.
PGSSL=false

# JWT (gere segredos longos e aleatórios em produção)
JWT_ACCESS_SECRET=troque-este-segredo-de-acesso
JWT_REFRESH_SECRET=troque-este-segredo-de-refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS (origens permitidas, separadas por vírgula)
CORS_ORIGINS=http://localhost:5000,http://localhost:8080
